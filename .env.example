# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Bedrock Model Configuration
# Use inference profile IDs for Bedrock models
# Amazon Nova Pro (no use case submission required)
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0

# Alternative: Claude 3.5 Sonnet (requires Anthropic use case submission)
# BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# Agent Configuration
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.7

# Logging
LOG_LEVEL=INFO
